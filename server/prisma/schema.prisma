generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  STAFF
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  COMPLETED
  REFUNDED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  fullName     String?
  phone        String?
  birthday     DateTime?
  gender       String?
  avatar       String?
  googleId     String?
  role         Role      @default(CUSTOMER)
  cart         Cart?
  orders       Order[]
  reviews      Review[]
  favorites    FavoriteProduct[]
  addresses    Address[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("users")
}

model FavoriteProduct {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("favorite_products")
}

model Address {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName        String
  phone           String
  province        String
  district        String
  ward            String
  detail          String
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("addresses")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id               String            @id @default(uuid())
  name             String
  slug             String            @unique
  description      String?
  brand            String?
  price            Decimal           @db.Decimal(10, 2)
  imageUrl         String?
  stock            Int               @default(0)
  isActive         Boolean           @default(true)
  isAvailable      Boolean           @default(true)
  isFlashSale      Boolean           @default(false)
  categoryId       String
  category         Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  cartItems        CartItem[]
  orderItems       OrderItem[]
  reviews          Review[]
  flashSaleItems   FlashSaleItem[]
  favoriteProducts FavoriteProduct[]
  cafeOrderItems   CafeOrderItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([categoryId])
  @@map("products")
}

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  status          OrderStatus @default(PENDING)
  totalAmount     Decimal     @db.Decimal(10, 2)
  shippingName    String
  shippingPhone   String
  shippingAddress String
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("reviews")
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  excerpt   String?
  content   String   @db.Text
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blogs")
}

model FlashSaleCampaign {
  id          String   @id @default(uuid())
  name        String
  startTime   DateTime
  endTime     DateTime
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  items       FlashSaleItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("flash_sale_campaigns")
}

model FlashSaleItem {
  id                 String   @id @default(uuid())
  campaignId         String
  campaign           FlashSaleCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  productId          String
  product            Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  discountPercentage Int      // 0-100
  stockLimit         Int      @default(0)
  soldCount          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([campaignId, productId])
  @@index([campaignId])
  @@index([productId])
  @@map("flash_sale_items")
}

model Banner {
  id        String   @id @default(uuid())
  title     String?
  imageUrl  String
  link      String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

// --- POS CAFE ENUMS ---

enum CafeTableStatus {
  EMPTY
  SERVING
  WAITING_PAYMENT
}

enum CafeOrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  E_WALLET
  CARD
}

// --- POS CAFE MODELS ---

model CafeTable {
  id        String          @id @default(uuid())
  name      String          @unique
  status    CafeTableStatus @default(EMPTY)
  isActive  Boolean         @default(true)
  orders    CafeOrder[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("cafe_tables")
}

model CafeOrder {
  id          String          @id @default(uuid())
  tableId     String
  table       CafeTable       @relation(fields: [tableId], references: [id], onDelete: Restrict)
  status      CafeOrderStatus @default(PENDING)
  totalAmount Decimal         @db.Decimal(10, 2)
  items       CafeOrderItem[]
  payments    Payment[]
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("cafe_orders")
}

model CafeOrderItem {
  id          String    @id @default(uuid())
  orderId     String
  order       CafeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String    // Lưu tên món tại thời điểm bán
  unitPrice   Decimal   @db.Decimal(10, 2) // Lưu giá tại thời điểm bán
  quantity    Int
  notes       String?   // Ghi chú món (ít đá, nhiều đường,...)
  createdAt   DateTime  @default(now())

  @@map("cafe_order_items")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String
  order         CafeOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  createdAt     DateTime      @default(now())

  @@map("payments")
}
